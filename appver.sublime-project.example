{
  "folders": [
    {
      "path": ".",
      "name": "appver",
      "file_exclude_patterns": [
        "*.sublime-workspace",
        "*.example",
      ],
      "folder_exclude_patterns": [
        ".*",
        "build",
        "dist",
        "venv",
        "__pycache__",
        "*.egg-info",
      ],
    },
  ],
  "settings": {
    "tab_size": 4,
    "default_line_ending": "unix",

    // Anaconda
    "python_interpreter": "$project_path/venv/Scripts/python",
  },
  "build_systems": [{
    "name": "venv Python",
    "shell": true,
    "encoding": "utf-8",
    "working_dir": "$project_path",
    "env": {
      "TWINE_USERNAME": "__token__",
      "TWINE_PASSWORD": "***",
    },
    "variants": [
      {
        "name": "Run current file",
        "file_regex": "^[ ]*File \"(...*?)\", line ([0-9]*)",
        "selector": "source.python",
        "cmd": ["$project_path/venv/Scripts/python", "-u", "$file"],
      },
      {
        "name": "Patch",
        "cmd": [
          "$project_path/venv/Scripts/python", "-u",
          "-m", "appver.__main__",
          "--patch", "$project_path/$project_base_name/_version.py",
        ],
      },
      {
        "name": "Minor",
        "cmd": [
          "$project_path/venv/Scripts/python", "-u",
          "-m", "appver.__main__",
          "--minor", "$project_path/$project_base_name/_version.py",
        ],
      },
      {
        "name": "Major",
        "cmd": [
          "$project_path/venv/Scripts/python", "-u",
          "-m", "appver.__main__",
          "--major", "$project_path/$project_base_name/_version.py",
        ],
      },
      {
        "name": "Upgrade dev-tools",
        "cmd": [
          "$project_path/venv/Scripts/python",
          "-m", "pip", "install", "--upgrade",
          "-r", "requirements-dev.txt",
        ],
      },
      {
        "name": "Build exe",
        "cmd": [
          "$project_path/venv/Scripts/python", "-u",
          "$project_path/$project_base_name/build_exe.py",
        ],
      },
      {
        "name": "Release",
        "cmd": ["$project_path/venv/Scripts/python", "-m", "build"],
      },
      {
        "name": "push Release to PYPI",
        "cmd": [
          "$project_path/venv/Scripts/python",
          "-m", "twine", "upload",
          "--skip-existing", "dist/*.tar.gz", "dist/*.whl",
        ],
      },
    ],
  }],
}
